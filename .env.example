# ============================================================
# MOSO Audit Tool — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# Public app URL (used to call /api/audit/run from /api/audit/submit)
NEXT_PUBLIC_APP_URL=https://www.moso.marketing

# AI — OpenAI
OPENAI_API_KEY=sk-...

# Performance data — Google PageSpeed Insights
# https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=AIza...

# Email delivery — Resend
# https://resend.com/docs/introduction
RESEND_API_KEY=re_...
# Must be a verified domain address in Resend
AUDIT_FROM_EMAIL=audits@moso.marketing
# Where contact form submissions are delivered
CONTACT_TO_EMAIL=info@moso.marketing

# Database — Supabase
# Found at: https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# CRM — Airtable
# https://airtable.com/developers/web/api/introduction
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_NAME=Inbound Leads

# Internal security key — used to protect /api/audit/run from external calls
# Generate with: openssl rand -hex 32
INTERNAL_JOB_KEY=
